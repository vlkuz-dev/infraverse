# Infraverse Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED SETTINGS
# ============================================

# Yandex Cloud OAuth token
# Get it from: https://oauth.yandex.ru/
# Required permissions: compute.viewer, vpc.viewer, resource-manager.viewer
YC_TOKEN=your_yandex_cloud_oauth_token_here

# NetBox API URL
# Must include /api/ suffix
# Example: https://netbox.example.com/api
NETBOX_URL=https://your-netbox-instance.com/api

# NetBox API token
# Create one in NetBox: Admin -> API Tokens
# Required permissions: write access to dcim.sites, virtualization.*, ipam.prefixes
NETBOX_TOKEN=your_netbox_api_token_here

# ============================================
# DATABASE
# ============================================

# SQLAlchemy database URL (default: sqlite:///infraverse.db)
# For SQLite, the file is created relative to the working directory.
# Examples:
#   sqlite:///infraverse.db          (relative path)
#   sqlite:////var/lib/infraverse.db (absolute path)
# DATABASE_URL=sqlite:///infraverse.db

# ============================================
# OPTIONAL: vCloud Director
# ============================================

# vCloud Director API URL
# Example: https://vcd.example.com
# VCD_URL=https://vcd.example.com

# vCloud Director credentials
# VCD_USER=admin
# VCD_PASSWORD=secret

# vCloud Director organization (default: System)
# VCD_ORG=System

# ============================================
# OPTIONAL: Zabbix
# ============================================

# Zabbix server URL
# Example: https://zabbix.example.com
# ZABBIX_URL=https://zabbix.example.com

# Zabbix credentials
# Supports both Zabbix <5.4 (user param) and 5.4+ (username param) automatically
# ZABBIX_USER=Admin
# ZABBIX_PASSWORD=zabbix

# ============================================
# OPTIONAL: Scheduler
# ============================================

# Background data ingestion interval in minutes (default: 0 = disabled)
# Set to a positive value to enable automatic fetching when running `infraverse serve`
# Example: SYNC_INTERVAL_MINUTES=30 fetches data every 30 minutes
# SYNC_INTERVAL_MINUTES=0

# ============================================
# OPTIONAL: External Links
# ============================================

# URL templates for linking VM and account detail pages to external systems.
# Use {placeholder} syntax for dynamic values.

# Yandex Cloud console VM link
# YC_CONSOLE_URL=https://console.yandex.cloud/folders/{folder_id}/compute/instances/{vm_id}

# Zabbix host link
# ZABBIX_HOST_URL=https://zabbix.example.com/hosts.php?form=update&hostid={host_id}

# NetBox VM link
# NETBOX_VM_URL=https://netbox.example.com/virtualization/virtual-machines/{vm_id}/

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Logging level (optional, defaults to INFO)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# TENANT / CLOUD ACCOUNT SETUP
# ============================================
# After installing, initialize the database and create a default tenant:
#
#   infraverse db init    # Create database tables
#   infraverse db seed    # Create "Default" tenant
#
# Tenant = customer/organization (e.g. "Customer A")
# CloudAccount = one cloud connection belonging to a tenant
#   Example: "Customer A" -> "YC Russia" (yandex_cloud), "vCloud@Dataspace" (vcloud)
#
# Cloud accounts are managed in the database. Each CloudAccount stores
# non-secret config (API endpoint, org name). Secrets stay in this .env file.
